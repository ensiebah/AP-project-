<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="750.0" spacing="15" style="-fx-background-color: #f8f9fa; -fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.secondhand.frontend.controller.MyAdvertisementsController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="My Published Advertisements" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleBackToMarket" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Back to Market" />
            </children>
        </HBox>
        <Separator />
        <ListView fx:id="myAdsListView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8;" />
    </children>
</VBox>