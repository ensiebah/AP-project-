<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="680" prefWidth="940" styleClass="app-shell" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.InboxController">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header"><children><Label text="S" styleClass="brand-mark"/><VBox spacing="1"><Label text="Messages" styleClass="brand-title"/><Label text="Keep conversations moving with buyers and sellers." styleClass="brand-subtitle"/></VBox><Region HBox.hgrow="ALWAYS"/><Button text="↻ Refresh" onAction="#loadUserConversations" styleClass="outline-button"/><Button text="← Market" onAction="#handleBackToMarket" styleClass="primary-action"/></children></HBox>
    </top>
    <center>
        <VBox styleClass="page-content"><children><VBox spacing="5"><Label text="YOUR INBOX" styleClass="page-kicker"/><Label text="Conversations and offers" styleClass="page-title"/><Label text="Double-click a conversation to open the chat." styleClass="section-subtitle"/></VBox><VBox styleClass="surface-card" VBox.vgrow="ALWAYS"><children><ListView fx:id="conversationListView" VBox.vgrow="ALWAYS"/></children></VBox></children></VBox>
    </center>
</BorderPane>
