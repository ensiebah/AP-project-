<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1180.0" styleClass="app-shell" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.MainMarketController">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <children>
                <Label text="S" styleClass="brand-mark" />
                <VBox spacing="1">
                    <Label text="SecondHand Market" styleClass="brand-title" />
                    <Label text="Discover something worth keeping" styleClass="brand-subtitle" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Browse" styleClass="nav-button" />
                <Button text="My ads" onAction="#goToMyAdvertisements" styleClass="nav-button" />
                <Button text="Saved" onAction="#goToFavorites" styleClass="nav-button" />
                <Button text="Messages" onAction="#goToInbox" styleClass="nav-button" />
                <Button fx:id="btnAdminPanel" text="Admin" onAction="#handleNavigateToAdmin" styleClass="nav-button" />
                <MenuButton text="EN / FA" styleClass="nav-button"><items><MenuItem text="English" onAction="#switchToEnglish"/><MenuItem text="فارسی" onAction="#switchToPersian"/></items></MenuButton>
                <Button text="+ Post an ad" onAction="#goToCreatAd" styleClass="primary-action" />
                <Button fx:id="profileButton" text="👤 Account" onAction="#goToDashboard" styleClass="profile-button" />
                <Button text="↪" onAction="#handleLogout" styleClass="icon-button danger-button" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox styleClass="page-content">
            <children>
                <VBox spacing="5">
                    <Label text="FIND YOUR NEXT THING" styleClass="page-kicker" />
                    <Label text="A better way to buy and sell locally" styleClass="page-title" />
                    <Label text="Search trusted ads, compare prices and connect with sellers." styleClass="section-subtitle" />
                </VBox>

                <VBox styleClass="filter-panel">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Search marketplace" styleClass="filter-heading" />
                            <Label text="Smart filters" styleClass="pill" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="Reset" onAction="#handleResetFilters" styleClass="outline-button" />
                            <Button text="Search ads" onAction="#handleSearch" styleClass="primary-action" />
                        </HBox>
                        <HBox spacing="10">
                            <children>
                                <TextField fx:id="searchField" promptText="What are you looking for?" HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="parentCategoryComboBox" prefWidth="150" promptText="Category" />
                                <ComboBox fx:id="categoryComboBox" prefWidth="155" promptText="Subcategory" />
                                <ComboBox fx:id="cityComboBox" prefWidth="140" promptText="City" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label text="Price" styleClass="muted-text" />
                                <TextField fx:id="minPriceField" prefWidth="125" promptText="From" />
                                <Label text="to" styleClass="muted-text" />
                                <TextField fx:id="maxPriceField" prefWidth="125" promptText="To" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="Sort" styleClass="muted-text" />
                                <MenuButton fx:id="sortMenuButton" text="Sort by: Date (Newest)" styleClass="outline-button" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="10" styleClass="surface-card">
                    <children>
                        <HBox alignment="CENTER_LEFT"><children><VBox spacing="2"><Label text="Explore by category" styleClass="section-title"/><Label text="Start broad, then narrow your search with subcategories." styleClass="section-subtitle"/></VBox><Region HBox.hgrow="ALWAYS"/><Label text="POPULAR" styleClass="pill"/></children></HBox>
                        <HBox spacing="10"><children><Button text="⌁  Digital" onAction="#quickFilterDigital" styleClass="quick-link" HBox.hgrow="ALWAYS"/><Button text="⌂  Home &amp; Kitchen" onAction="#quickFilterHome" styleClass="quick-link" HBox.hgrow="ALWAYS"/><Button text="▱  Vehicles" onAction="#quickFilterVehicles" styleClass="quick-link" HBox.hgrow="ALWAYS"/><Button text="★  Entertainment" onAction="#quickFilterEntertainment" styleClass="quick-link" HBox.hgrow="ALWAYS"/></children></HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="2">
                            <Label text="Latest ads" styleClass="section-title" />
                            <Label text="Click a card to see details. Hover cards with multiple photos to preview the gallery." styleClass="section-subtitle" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="LOCAL MARKETPLACE" styleClass="pill" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <TilePane fx:id="advertisementsTilePane" prefColumns="3" prefTileWidth="280" hgap="18" vgap="18" styleClass="market-ad-grid" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>
