<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane styleClass="login-root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.RegisterController">
    <children>
        <Pane style="-fx-background-image: url('/images/login-background.png'); -fx-background-size: cover; -fx-background-position: center; -fx-opacity: .18;" />
        <VBox maxWidth="480" alignment="CENTER" spacing="15" styleClass="login-card">
            <children>
                <HBox alignment="CENTER" spacing="10">
                    <Label text="S" styleClass="brand-mark" />
                    <Label text="Create your marketplace account" styleClass="section-title" />
                </HBox>
                <Label text="Join the community and start buying or selling in minutes." styleClass="section-subtitle" wrapText="true" textAlignment="CENTER" />
                <Region prefHeight="5" />
                <TextField fx:id="fullNameField" promptText="Full name" maxWidth="Infinity" styleClass="modern-textfield" />
                <TextField fx:id="usernameField" promptText="Username" maxWidth="Infinity" styleClass="modern-textfield" />
                <PasswordField fx:id="passwordField" promptText="Password" maxWidth="Infinity" styleClass="modern-textfield" />
                <TextField fx:id="phoneField" promptText="Phone number" maxWidth="Infinity" styleClass="modern-textfield" />
                <TextField fx:id="emailField" promptText="Email address" maxWidth="Infinity" styleClass="modern-textfield" />
                <Button text="Create account" onAction="#register" maxWidth="Infinity" styleClass="primary-button" />
                <Button text="← Back to sign in" onAction="#goToLogin" maxWidth="Infinity" styleClass="secondary-button" />
                <Label fx:id="messageLabel" styleClass="message-label" wrapText="true" />
            </children>
        </VBox>
    </children>
</StackPane>
