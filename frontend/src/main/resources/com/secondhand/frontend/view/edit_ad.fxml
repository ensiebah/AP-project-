<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="920" prefHeight="730" styleClass="app-shell" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.EditAdController">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <children>
                <Label text="S" styleClass="brand-mark" />
                <VBox spacing="1"><Label text="Edit your advertisement" styleClass="brand-title"/><Label text="Keep your advertisement accurate and attractive." styleClass="brand-subtitle"/></VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Cancel" onAction="#handleCancel" styleClass="outline-button" />
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox styleClass="page-content" prefWidth="840">
                    <children>
                        <VBox styleClass="surface-card" spacing="17">
                            <children>
                                <VBox spacing="4"><Label text="ADVERTISEMENT DETAILS" styleClass="page-kicker"/><Label text="Update your advertisement" styleClass="page-title"/><Label text="Changes are saved directly to your advertisement." styleClass="section-subtitle"/></VBox>
                                <GridPane hgap="14" vgap="13">
                                    <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                    <children>
                                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0"><Label text="Title" styleClass="muted-text"/><TextField fx:id="titleField"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0"><Label text="Price" styleClass="muted-text"/><TextField fx:id="priceField"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1"><Label text="Category" styleClass="muted-text"/><ComboBox fx:id="parentCategoryComboBox" promptText="Choose a broad category" maxWidth="Infinity"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1"><Label text="Subcategory" styleClass="muted-text"/><ComboBox fx:id="categoryComboBox" promptText="Choose a subcategory" maxWidth="Infinity"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2"><Label text="City" styleClass="muted-text"/><ComboBox fx:id="cityComboBox" promptText="Choose your city" maxWidth="Infinity"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3"><Label text="Description" styleClass="muted-text"/><TextArea fx:id="descriptionArea" prefHeight="120" wrapText="true"/></VBox>
                                    </children>
                                </GridPane>
                                <Separator />
                                <VBox spacing="9"><Label text="Advertisement photos" styleClass="section-title"/><Label text="Drag photos to reorder them, or remove photos you no longer want." styleClass="section-subtitle"/><ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;"><content><HBox fx:id="imagesContainer" spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 9; -fx-background-color: #f7fbff; -fx-background-radius: 12;"/></content></ScrollPane><Button text="＋ Add new picture(s)" onAction="#handleAddNewPicture" styleClass="outline-button"/></VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="10"><children><Button text="Cancel" onAction="#handleCancel" styleClass="outline-button"/><Button text="Save changes" onAction="#handleUpdateAdvertisement" styleClass="primary-action"/></children></HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
