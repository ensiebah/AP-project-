<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="1200" prefHeight="760" styleClass="app-shell" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.AdminPanelController">
    <top>
        <VBox>
            <children>
                <HBox alignment="CENTER_LEFT" styleClass="app-header">
                    <children>
                        <Label text="S" styleClass="brand-mark" />
                        <VBox spacing="1">
                            <Label text="SecondHand Admin" styleClass="brand-title" />
                            <Label text="Marketplace operations workspace" styleClass="brand-subtitle" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="ADMINISTRATOR" styleClass="pill" />
                        <Button fx:id="overviewNavButton" text="Overview" onAction="#showOverview" styleClass="nav-button" />
                        <MenuButton fx:id="advertisementsMenuButton" text="Advertisements" prefWidth="250" styleClass="ad-status-menu">
                            <graphic><Label text="▦" styleClass="ad-status-menu-icon" /></graphic>
                            <items>
                                <MenuItem fx:id="allAdsMenuItem" text="All advertisements" onAction="#showAllAds" styleClass="status-all-menu">
                                    <graphic><Label text="●" styleClass="menu-status-dot dot-all" /></graphic>
                                </MenuItem>
                                <MenuItem fx:id="pendingAdsMenuItem" text="Pending approval" onAction="#showPendingAds" styleClass="status-pending-menu">
                                    <graphic><Label text="●" styleClass="menu-status-dot dot-pending" /></graphic>
                                </MenuItem>
                                <MenuItem fx:id="activeAdsMenuItem" text="Approved advertisements" onAction="#showActiveAds" styleClass="status-active-menu">
                                    <graphic><Label text="●" styleClass="menu-status-dot dot-active" /></graphic>
                                </MenuItem>
                                <MenuItem fx:id="rejectedAdsMenuItem" text="Rejected advertisements" onAction="#showRejectedAds" styleClass="status-rejected-menu">
                                    <graphic><Label text="●" styleClass="menu-status-dot dot-rejected" /></graphic>
                                </MenuItem>
                                <MenuItem fx:id="soldAdsMenuItem" text="Sold out advertisements" onAction="#showSoldAds" styleClass="status-sold-menu">
                                    <graphic><Label text="●" styleClass="menu-status-dot dot-sold" /></graphic>
                                </MenuItem>
                                <MenuItem fx:id="deletedAdsMenuItem" text="Deleted advertisements" onAction="#showDeletedAds" styleClass="status-deleted-menu">
                                    <graphic><Label text="●" styleClass="menu-status-dot dot-deleted" /></graphic>
                                </MenuItem>
                            </items>
                        </MenuButton>
                        <Button fx:id="categoriesNavButton" text="Categories" onAction="#showCategories" styleClass="nav-button" />
                        <Button fx:id="usersNavButton" text="Users" onAction="#showUsers" styleClass="nav-button" />
                        <Button text="Sign out" onAction="#handleLogout" styleClass="danger-button" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <StackPane fx:id="contentStack" style="-fx-padding: 28 42 36 42;">
            <children>
                <!-- Overview is the default landing screen. -->
                <VBox fx:id="overviewPane" spacing="19">
                    <children>
                        <VBox spacing="5">
                            <Label text="ADMINISTRATION OVERVIEW" styleClass="page-kicker" />
                            <Label text="Your marketplace at a glance" styleClass="page-title" />
                            <Label text="Monitor moderation, community size and marketplace data from one place." styleClass="section-subtitle" />
                        </VBox>

                        <HBox spacing="13">
                            <children>
                                <VBox styleClass="metric-card" HBox.hgrow="ALWAYS"><children><Label fx:id="totalAdsLabel" text="–" styleClass="metric-number"/><Label text="Total advertisements" styleClass="metric-label"/></children></VBox>
                                <VBox styleClass="metric-card" HBox.hgrow="ALWAYS"><children><Label fx:id="pendingAdsLabel" text="–" styleClass="metric-number"/><Label text="Awaiting review" styleClass="metric-label"/></children></VBox>
                                <VBox styleClass="metric-card" HBox.hgrow="ALWAYS"><children><Label fx:id="activeAdsLabel" text="–" styleClass="metric-number"/><Label text="Published ads" styleClass="metric-label"/></children></VBox>
                                <VBox styleClass="metric-card" HBox.hgrow="ALWAYS"><children><Label fx:id="totalUsersLabel" text="–" styleClass="metric-number"/><Label text="Registered users" styleClass="metric-label"/></children></VBox>
                            </children>
                        </HBox>

                        <HBox spacing="13">
                            <children>
                                <VBox styleClass="metric-card" HBox.hgrow="ALWAYS"><children><Label fx:id="totalCitiesLabel" text="–" styleClass="metric-number"/><Label text="Available cities" styleClass="metric-label"/></children></VBox>
                                <VBox styleClass="metric-card" HBox.hgrow="ALWAYS"><children><Label fx:id="totalCategoriesLabel" text="–" styleClass="metric-number"/><Label text="Categories &amp; subcategories" styleClass="metric-label"/></children></VBox>
                                <VBox styleClass="metric-card" HBox.hgrow="ALWAYS"><children><Label fx:id="rejectedAdsLabel" text="–" styleClass="metric-number"/><Label text="Rejected ads" styleClass="metric-label"/></children></VBox>
                                <VBox styleClass="metric-card" HBox.hgrow="ALWAYS"><children><Label fx:id="soldAdsLabel" text="–" styleClass="metric-number"/><Label text="Sold ads" styleClass="metric-label"/></children></VBox>
                            </children>
                        </HBox>

                        <HBox spacing="18" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="11" styleClass="surface-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Moderation queue" styleClass="section-title" />
                                        <Label text="Pending advertisements are waiting for an administrator decision." styleClass="section-subtitle" wrapText="true" />
                                        <Button text="Review pending advertisements" onAction="#showPendingAds" styleClass="primary-action" />
                                    </children>
                                </VBox>
                                <VBox spacing="11" styleClass="surface-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Community safety" styleClass="section-title" />
                                        <Label fx:id="blockedUsersLabel" text="–" styleClass="metric-number" />
                                        <Label text="Blocked users. Open Users to search, review and restore accounts." styleClass="section-subtitle" wrapText="true" />
                                        <Button text="Open user directory" onAction="#showUsers" styleClass="outline-button" />
                                    </children>
                                </VBox>
                                <VBox spacing="11" styleClass="surface-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Category structure" styleClass="section-title" />
                                        <Label text="Browse every main category and its subcategories in one hierarchy." styleClass="section-subtitle" wrapText="true" />
                                        <Button text="Open category explorer" onAction="#showCategories" styleClass="outline-button" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Advertisement status screen -->
                <VBox fx:id="advertisementsPane" visible="false" managed="false" spacing="16">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="4"><Label text="ADVERTISEMENT MODERATION" styleClass="page-kicker"/><Label fx:id="advertisementsTitleLabel" text="Pending approval advertisements" styleClass="page-title"/><Label text="Select an advertisement to approve or reject it. The menu in the top bar filters every lifecycle state." styleClass="section-subtitle"/></VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="STATUS FILTER" styleClass="pill" />
                            </children>
                        </HBox>
                        <VBox spacing="10" styleClass="surface-card" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT"><children><Label text="Status workspace" styleClass="section-title"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="advertisementsSummaryLabel" text="Loading advertisements…" styleClass="pill"/></children></HBox>
                                <Label text="Choose another status from the Advertisements menu in the top bar. Each card exposes only safe actions for its current lifecycle state." styleClass="section-subtitle" wrapText="true" />
                                <ListView fx:id="advertisementsListView" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Full category CRUD with safe deletion rules. -->
                <VBox fx:id="categoriesPane" visible="false" managed="false" spacing="16">
                    <children>
                        <VBox spacing="5"><Label text="CATEGORY MANAGEMENT" styleClass="page-kicker"/><Label text="Marketplace category hierarchy" styleClass="page-title"/><Label text="Create roots and subcategories, rename them, or safely delete unused leaf categories." styleClass="section-subtitle"/></VBox>
                        <HBox spacing="18" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="12" styleClass="surface-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT"><children><Label text="All categories" styleClass="section-title"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="categoryTreeSummaryLabel" text="Loading categories…" styleClass="pill"/></children></HBox>
                                        <TreeView fx:id="categoriesTreeView" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                                <VBox spacing="13" prefWidth="330" styleClass="surface-card">
                                    <children>
                                        <Label text="Manage selection" styleClass="section-title" />
                                        <Label fx:id="selectedCategoryInfoLabel" text="Select a category to add a child, rename it or delete it." wrapText="true" styleClass="section-subtitle" />
                                        <Separator />
                                        <Label text="Category name" styleClass="muted-text" />
                                        <TextField fx:id="categoryNameField" promptText="e.g. Mobile Phones" />
                                        <Button text="＋ Add main category" onAction="#addRootCategory" maxWidth="Infinity" styleClass="primary-action" />
                                        <Button fx:id="addSubcategoryButton" text="↳ Add subcategory to selected" onAction="#addSubcategory" maxWidth="Infinity" styleClass="outline-button" />
                                        <Button fx:id="renameCategoryButton" text="✎ Rename selected" onAction="#renameSelectedCategory" maxWidth="Infinity" styleClass="outline-button" />
                                        <Separator />
                                        <Label text="Safe deletion" styleClass="section-title" />
                                        <Label text="A category can be deleted only if no advertisement uses it and it has no child categories." wrapText="true" styleClass="section-subtitle" />
                                        <Button fx:id="deleteCategoryButton" text="Delete selected category" onAction="#deleteSelectedCategory" maxWidth="Infinity" styleClass="danger-button" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- One standard users directory, not two half-page lists -->
                <VBox fx:id="usersPane" visible="false" managed="false" spacing="16">
                    <children>
                        <VBox spacing="5"><Label text="USER DIRECTORY" styleClass="page-kicker"/><Label text="Community members" styleClass="page-title"/><Label text="Search the complete directory, filter by account status and block or restore an account." styleClass="section-subtitle"/></VBox>
                        <VBox spacing="13" styleClass="surface-card" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox spacing="9" alignment="CENTER_LEFT"><children><TextField fx:id="userSearchField" promptText="Search by name or username…" HBox.hgrow="ALWAYS"/><Button fx:id="allUsersButton" text="All users" onAction="#showAllUsers" styleClass="filter-selected"/><Button fx:id="activeUsersButton" text="Active" onAction="#showActiveUsers" styleClass="outline-button"/><Button fx:id="blockedUsersButton" text="Blocked" onAction="#showBlockedUsers" styleClass="outline-button"/></children></HBox>
                                <HBox alignment="CENTER_LEFT"><children><Label fx:id="usersListSummaryLabel" text="Loading users…" styleClass="pill"/><Region HBox.hgrow="ALWAYS"/><Label text="Use the action on each card to change account status." styleClass="muted-text"/></children></HBox>
                                <ListView fx:id="usersListView" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </center>
</BorderPane>
