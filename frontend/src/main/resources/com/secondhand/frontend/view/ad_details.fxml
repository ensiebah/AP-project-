<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="760" prefWidth="1080" styleClass="app-shell" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.AdDetailsController">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header"><children><Label text="S" styleClass="brand-mark"/><VBox spacing="1"><Label text="Advertisement details" styleClass="brand-title"/><Label text="Everything you need before making an offer." styleClass="brand-subtitle"/></VBox><Region HBox.hgrow="ALWAYS"/><Button text="← Back" onAction="#handleBack" styleClass="outline-button"/></children></HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;"><content>
            <VBox styleClass="page-content" prefWidth="1000"><children>
                <HBox spacing="20"><children>
                    <StackPane fx:id="imageContainer" prefWidth="475" prefHeight="335" style="-fx-background-color: #eaf4ff; -fx-background-radius: 18; -fx-border-color: #d7e8f9; -fx-border-radius: 18;"><children>
                        <ImageView fx:id="adImageView" fitHeight="310" fitWidth="450" preserveRatio="true" />
                        <Button fx:id="btnPrevImage" onAction="#handlePrevImage" visible="false" text="‹" styleClass="icon-button outline-button" StackPane.alignment="CENTER_LEFT" />
                        <Button fx:id="btnNextImage" onAction="#handleNextImage" visible="false" text="›" styleClass="icon-button outline-button" StackPane.alignment="CENTER_RIGHT" />
                    </children></StackPane>
                    <VBox spacing="13" styleClass="surface-card" HBox.hgrow="ALWAYS"><children>
                        <Label text="LISTING" styleClass="page-kicker"/><Label fx:id="titleLabel" text="Advertisement title" wrapText="true" styleClass="page-title"/><Label fx:id="priceLabel" text="$0.00" styleClass="ad-price"/>
                        <Separator/>
                        <GridPane hgap="12" vgap="10"><children>
                            <Label text="Category" styleClass="muted-text" GridPane.columnIndex="0" GridPane.rowIndex="0"/><Label fx:id="categoryLabel" styleClass="ad-meta" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label text="City" styleClass="muted-text" GridPane.columnIndex="0" GridPane.rowIndex="1"/><Label fx:id="cityLabel" styleClass="ad-meta" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label text="Seller" styleClass="muted-text" GridPane.columnIndex="0" GridPane.rowIndex="2"/><VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="2"><children><Label fx:id="sellerLabel" styleClass="ad-meta"/><Label fx:id="ratingLabel" text="Rating: 0.0 / 5.0" styleClass="ad-meta"/></children></VBox>
                        </children></GridPane>
                        <Region VBox.vgrow="ALWAYS"/>
                        <HBox spacing="8"><children><Button fx:id="btnFavorite" text="♡ Save" onAction="#handleToggleFavorite" styleClass="outline-button"/><Button fx:id="btnChatWithSeller" text="Message seller" onAction="#handleChatWithSeller" styleClass="primary-action"/></children></HBox>
                        <HBox spacing="8"><children><Button fx:id="btnRateSeller" text="Rate seller" onAction="#handleRateSeller" styleClass="outline-button"/><Button fx:id="btnEdit" text="Edit" onAction="#handleEditAd" visible="false" managed="false" styleClass="outline-button"/><Button fx:id="btnMarkAsSold" text="Mark sold" onAction="#handleMarkAsSold" visible="false" managed="false" styleClass="success-button"/><Button fx:id="btnDelete" text="Delete" onAction="#handleDeleteAd" visible="false" managed="false" styleClass="danger-button"/></children></HBox>
                    </children></VBox>
                </children></HBox>
                <HBox spacing="20"><children>
                    <VBox spacing="10" styleClass="surface-card" HBox.hgrow="ALWAYS"><children><Label text="Description" styleClass="section-title"/><TextArea fx:id="descriptionArea" editable="false" prefHeight="105" wrapText="true"/></children></VBox>
                    <VBox spacing="9" styleClass="surface-card" HBox.hgrow="ALWAYS"><children><Label text="Ask the seller" styleClass="section-title"/><HBox spacing="8"><children><TextField fx:id="newCommentField" promptText="Ask a question about this item…" HBox.hgrow="ALWAYS"/><Button text="Send" onAction="#handleSendProductComment" styleClass="primary-action"/></children></HBox><HBox spacing="7"><children><Button fx:id="btnTabProductComments" text="Questions" onAction="#switchTabToProductComments" styleClass="outline-button"/><Button fx:id="btnTabSellerRatings" text="Seller ratings" onAction="#switchTabToSellerRatings" styleClass="outline-button"/></children></HBox><ListView fx:id="commentsListView" prefHeight="100"/></children></VBox>
                </children></HBox>
            </children></VBox>
        </content></ScrollPane>
    </center>
</BorderPane>
