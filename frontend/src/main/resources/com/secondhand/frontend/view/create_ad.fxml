<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="920" prefHeight="730" styleClass="app-shell" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.CreateAdController">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header">
            <children>
                <Label text="S" styleClass="brand-mark" />
                <VBox spacing="1"><Label text="Post an advertisement" styleClass="brand-title"/><Label text="Tell buyers why your item is worth discovering." styleClass="brand-subtitle"/></VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="← Back to market" onAction="#goBackToMarket" styleClass="outline-button" />
            </children>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox styleClass="page-content" prefWidth="840">
                    <children>
                        <VBox styleClass="surface-card" spacing="18">
                            <children>
                                <VBox spacing="4"><Label text="LIST SOMETHING GREAT" styleClass="page-kicker"/><Label text="Create your advertisement" styleClass="page-title"/><Label text="Complete the key information so the right buyers can find it." styleClass="section-subtitle"/></VBox>
                                <GridPane hgap="14" vgap="13">
                                    <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                    <children>
                                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0"><Label text="Title" styleClass="muted-text"/><TextField fx:id="titleField" promptText="e.g. iPhone 13 Pro Max"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0"><Label text="Price" styleClass="muted-text"/><TextField fx:id="priceField" promptText="e.g. 750.00"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1"><Label text="Category" styleClass="muted-text"/><ComboBox fx:id="parentCategoryComboBox" promptText="Choose a broad category" maxWidth="Infinity"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1"><Label text="Subcategory" styleClass="muted-text"/><ComboBox fx:id="categoryComboBox" promptText="Choose a subcategory" maxWidth="Infinity"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2"><Label text="City" styleClass="muted-text"/><ComboBox fx:id="cityComboBox" promptText="Choose your city" maxWidth="Infinity"/></VBox>
                                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="3"><Label text="Description" styleClass="muted-text"/><TextArea fx:id="descriptionArea" prefHeight="115" promptText="Describe condition, age, specifications and anything a buyer should know." wrapText="true"/></VBox>
                                    </children>
                                </GridPane>
                                <Separator />
                                <HBox spacing="18" alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS"><Label text="Photos" styleClass="section-title"/><Label text="A clear photo improves your advertisement. You can select multiple images." styleClass="section-subtitle"/><Button text="⌑  Select image(s)" onAction="#handleSelectImage" styleClass="outline-button"/></VBox>
                                        <VBox alignment="CENTER" prefWidth="190" prefHeight="115" style="-fx-background-color: #f4f9ff; -fx-background-radius: 14; -fx-border-color: #d9eafa; -fx-border-radius: 14; -fx-border-style: segments(4, 4);"><children><ImageView fx:id="imagePreview" fitWidth="170" fitHeight="100" preserveRatio="true"/></children></VBox>
                                    </children>
                                </HBox>
                                <Label fx:id="errorLabel" styleClass="message-label" wrapText="true" />
                                <HBox alignment="CENTER_RIGHT" spacing="10"><children><Button text="Clear form" onAction="#handleCancel" styleClass="outline-button"/><Button fx:id="publishButton" text="Publish advertisement" onAction="#handleSaveAdvertisement" styleClass="primary-action"/></children></HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
