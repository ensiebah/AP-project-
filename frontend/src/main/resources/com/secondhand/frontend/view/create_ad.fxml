<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="630.0" prefWidth="480.0" spacing="15" style="-fx-background-color: #f8f9fa; -fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.secondhand.frontend.controller.CreateAdController">
    <children>

        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-padding: 12; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);">
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #343a40;" text="Post New Advertisement" HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                    <children>
                        <Button mnemonicParsing="false" onAction="#goBackToMarket" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="← Market" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <TextField fx:id="titleField" promptText="Ad Title (e.g., iPhone 13)" style="-fx-pref-height: 35; -fx-background-radius: 6;" />

        <ComboBox fx:id="categoryComboBox" promptText="Select Category" style="-fx-pref-width: 450; -fx-pref-height: 35; -fx-background-radius: 6;" />

        <TextField fx:id="priceField" promptText="Price (in USD)" style="-fx-pref-height: 35; -fx-background-radius: 6;" />

        <ComboBox fx:id="cityComboBox" promptText="Select City" style="-fx-pref-width: 450; -fx-pref-height: 35; -fx-background-radius: 6;" />

        <TextArea fx:id="descriptionArea" promptText="Describe your item in detail..." style="-fx-pref-height: 120; -fx-background-radius: 6; -fx-border-radius: 6;" wrapText="true" />

        <HBox alignment="CENTER_LEFT" spacing="15">
            <children>
                <Button onAction="#handleSelectImage" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 35; -fx-background-radius: 6; -fx-cursor: hand;" text="Choose Image" />
                <StackPane style="-fx-background-color: #eee; -fx-border-color: #ddd; -fx-min-width: 80; -fx-min-height: 60; -fx-max-width: 80; -fx-max-height: 60; -fx-background-radius: 6; -fx-border-radius: 6;">
                    <children>
                        <ImageView fx:id="imagePreview" fitHeight="58" fitWidth="78" preserveRatio="true" />
                    </children>
                </StackPane>
            </children>
        </HBox>

        <Label fx:id="errorLabel" style="-fx-text-fill: #dc3545; -fx-font-weight: bold;" />

        <HBox spacing="12.0" alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#handleCancel" prefWidth="120.0" style="-fx-background-color: #e2e8f0; -fx-text-fill: #4a5568; -fx-font-weight: bold; -fx-pref-height: 40; -fx-background-radius: 6; -fx-cursor: hand;" text="Cancel" />

                <Button HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" onAction="#handleSaveAdvertisement" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 40; -fx-background-radius: 6; -fx-cursor: hand;" text="Publish Ad" />
            </children>
        </HBox>

    </children>
</VBox>