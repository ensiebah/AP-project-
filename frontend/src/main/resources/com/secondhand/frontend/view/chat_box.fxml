<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="590" prefWidth="540" styleClass="app-shell" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.secondhand.frontend.controller.ChatController">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="app-header"><children><Label text="✉" styleClass="brand-mark"/><VBox spacing="2" HBox.hgrow="ALWAYS"><Label fx:id="chatTitleLabel" text="Conversation" styleClass="brand-title"/><Label fx:id="adTitleLabel" text="Advertisement" styleClass="brand-subtitle"/></VBox><Button text="Close" onAction="#handleCloseWindow" styleClass="outline-button"/></children></HBox>
    </top>
    <center>
        <VBox style="-fx-padding: 20 24 12 24;" spacing="12"><children><ListView fx:id="messageListView" VBox.vgrow="ALWAYS"/></children></VBox>
    </center>
    <bottom>
        <HBox spacing="10" style="-fx-padding: 12 24 22 24;"><children><TextField fx:id="messageInputField" promptText="Write a message…" HBox.hgrow="ALWAYS"/><Button text="Send" onAction="#handleSendMessage" styleClass="primary-action"/></children></HBox>
    </bottom>
</BorderPane>
