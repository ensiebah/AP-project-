<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="550.0" prefWidth="450.0" spacing="12.0" style="-fx-background-color: #f1f3f5; -fx-padding: 15;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.secondhand.frontend.controller.ChatController">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #ffffff; -fx-padding: 12; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 4, 0, 0, 0);">
            <children>
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="chatTitleLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #212529;" text="Loading Chat..." />
                        <Label fx:id="adTitleLabel" style="-fx-font-size: 11px; -fx-text-fill: #6c757d;" text="Ad details" />
                    </children>
                </VBox>
                <Button onAction="#handleCloseWindow"
                        style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        text="✕ Close" />
            </children>
        </HBox>

        <ListView fx:id="messageListView" style="-fx-background-radius: 10; -fx-border-color: #dee2e6; -fx-border-radius: 10; -fx-background-color: white;" VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER" spacing="10.0">
            <children>
                <TextField fx:id="messageInputField" promptText="Type a message..." style="-fx-pref-height: 38; -fx-background-radius: 8; -fx-border-color: #ced4da; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" />
                <Button onAction="#handleSendMessage" prefWidth="85.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 38; -fx-background-radius: 8; -fx-cursor: hand;" text="Send" />
            </children>
        </HBox>

    </children>
</VBox>